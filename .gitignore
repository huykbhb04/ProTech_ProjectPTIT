# =============================================================
# DEPENDENCIES - Tất cả thư viện cài đặt tự động
# =============================================================

# Node.js
node_modules/
*/node_modules/
**/node_modules/

# Python virtual environment (ai_service)
ai_service/venv/
ai_service/__pycache__/
ai_service/*.pyc
ai_service/*.pyo
ai_service/*.pyd
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
*.egg-info/
dist-info/
.eggs/

